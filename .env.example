# Copy this file to .env and fill in your values.
# Never commit .env to version control.

DATABASE_URL=postgresql://user:password@host:5432/dbname
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
GEMINI_API_KEY=your-gemini-api-key   # Used for translation quality loop
DEEPSEEK_API_KEY=                    # Optional — get a free key at platform.deepseek.com
BRAVE_SEARCH_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=   # Optional — get a free key at semanticscholar.org/product/api for higher rate limits
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256

# Email (for forgot-password). Leave blank to log reset links to the console instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your@gmail.com
FRONTEND_URL=http://localhost:5173
