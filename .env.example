# Copy this file to .env and fill in your values.
# Never commit .env to version control.

DATABASE_URL=postgresql://user:password@host:5432/dbname
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
GEMINI_API_KEY=your-gemini-api-key   # Used for translation quality loop
DEEPSEEK_API_KEY=                    # Optional — get a free key at platform.deepseek.com
DEEPGRAM_API_KEY=                    # For audio/video files >25 MB — free $200 credit at deepgram.com

# S3 file upload (bypasses Lambda 6 MB limit — files up to 200 MB)
AWS_REGION=ap-southeast-2
S3_UPLOAD_BUCKET=your-bucket-name
# Leave blank on Lambda — it uses the execution role automatically
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BRAVE_SEARCH_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=   # Optional — get a free key at semanticscholar.org/product/api for higher rate limits
CORE_API_KEY=               # Optional — used for CORE academic full-text search
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ENCRYPTION_KEY=             # Optional but recommended — encrypts stored connector/API secrets at rest

# Google OAuth (Gmail integration)
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/email/callback

# Microsoft Teams integration
# Register an app at portal.azure.com → Microsoft Entra ID → App registrations
# Redirect URI to set in Azure: http://localhost:8000/api/teams/callback
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_TENANT_ID=       # Leave blank to use "organizations" (work/school accounts only)
TEAMS_REDIRECT_URI=http://localhost:8000/api/teams/callback

# Microsoft OneDrive integration (Books Library — admin-only OneDrive sync)
# Register an app at portal.azure.com → Microsoft Entra ID → App registrations
# Redirect URI to set in Azure: http://localhost:8000/api/admin/books/onedrive/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Leave blank to use "common" (personal + work/school accounts)
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/admin/books/onedrive/callback
# Optional: OneDrive item ID of the books folder (takes priority over path)
ONEDRIVE_BOOKS_FOLDER_ID=
# Optional: folder path relative to OneDrive root, e.g. Books
ONEDRIVE_BOOKS_FOLDER_PATH=
ONEDRIVE_SYNC_ENABLED=true

# GitHub OAuth (repo / issues / PR / branch workflows)
# Create an OAuth app at github.com/settings/developers
# Callback URL to set in GitHub: http://localhost:8000/api/connectors/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/connectors/github/callback

# Jira OAuth (Atlassian Cloud)
# Create an OAuth 2.0 integration at developer.atlassian.com/console
# Callback URL to set in Atlassian: http://localhost:8000/api/connectors/jira/callback
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:8000/api/connectors/jira/callback

# Spotify OAuth (playback controls)
# Create an app at developer.spotify.com/dashboard
# Redirect URI to set in Spotify: http://127.0.0.1:8000/api/connectors/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/connectors/spotify/callback

# Email (for forgot-password). Leave blank to log reset links to the console instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your@gmail.com
FRONTEND_URL=http://localhost:5173

# ── Deployment (set these as GitHub Actions secrets, not in .env) ─────────────
# AWS Lambda / ECR
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-2
# ECR_REPOSITORY=memolink-backend
# LAMBDA_FUNCTION_NAME=memolink-api

# Azure Static Web Apps
# AZURE_STATIC_WEB_APPS_API_TOKEN=   (from Azure portal → Static Web App → Manage deployment token)

# Frontend build (your API Gateway or Lambda Function URL)
# VITE_API_BASE_URL=https://xxxxxxxxxx.execute-api.ap-southeast-2.amazonaws.com
