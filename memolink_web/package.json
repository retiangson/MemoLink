{
  "name": "memolink_web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "node scripts/dev-electron.mjs",
    "build": "vite build",
    "build:electron": "node scripts/build-electron.mjs && electron-builder",
    "build:electron:publish": "node scripts/build-electron.mjs && electron-builder --publish always",
    "build:android": "vite build && cap sync android",
    "preview": "vite preview",
    "postinstall": "patch-package"
  },
  "build": {
    "appId": "com.memolink.desktop",
    "productName": "MemoLink",
    "icon": "public/memolink-icon.png",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "retiangson",
      "repo": "MemoLink"
    },
    "extraResources": [
      {
        "from": "../memolink_backend/whatsapp_bridge",
        "to": "whatsapp_bridge",
        "filter": [
          "bridge.js",
          "package.json",
          "node_modules/**"
        ]
      },
      {
        "from": "extraResources/node.exe",
        "to": "node.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "MemoLink-Setup.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@capacitor-community/text-to-speech": "^8.0.2",
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/status-bar": "^8.0.2",
    "@lingo-reader/mobi-parser": "^0.4.6",
    "@tiptap/extension-color": "^3.23.4",
    "@tiptap/extension-highlight": "^3.23.4",
    "@tiptap/extension-image": "^3.23.4",
    "@tiptap/extension-link": "^3.23.4",
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/extension-table": "^3.23.4",
    "@tiptap/extension-task-item": "^3.23.4",
    "@tiptap/extension-task-list": "^3.23.4",
    "@tiptap/extension-text-align": "^3.23.4",
    "@tiptap/extension-text-style": "^3.23.4",
    "@tiptap/extension-underline": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "docx": "^9.6.1",
    "electron-updater": "^6.8.9",
    "epubjs": "^0.3.93",
    "highlight.js": "^11.11.1",
    "html-to-docx": "^1.8.0",
    "html2pdf.js": "^0.14.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.25",
    "marked": "^17.0.0",
    "node-unrar-js": "^2.0.2",
    "pdfjs-dist": "^6.0.227",
    "playwright-core": "^1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-joyride": "^3.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "turndown": "^7.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.22",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.7.2",
    "vite": "^7.2.2",
    "vite-plugin-electron": "^1.0.4"
  }
}
